{
    "compilerOptions": {
      "rootDirs": ["src"],
      "outDir": "dist",
      "lib": ["es2020", "DOM"],
      "target": "es2020",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "types": ["node"],
      "module": "commonjs",
      "skipLibCheck": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules",".api","client"],
}
